Problem: Palindrome Number
Difficulty: Easy

class Solution {
    public boolean isPalindrome(int x) {
        if(x<0)
        {
            return false;
        }
        int o=x;
        int sum=0;
        while(x!=0)
        {
            int rem=x%10;
            sum=(sum*10)+rem;
            x=x/10;
        }
        if(o==sum)
        {
            return true;
        }
        return false;
    }
    
}
