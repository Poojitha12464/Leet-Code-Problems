Problem: Unique Middle Element
Difficulty: Easy

class Solution {
    public boolean isMiddleElementUnique(int[] nums) {
        int n=nums.length;
        int mid=n/2;
        int c=0;
        for(int i=0;i<n;i++)
            {
               if(nums[i]==nums[mid]) c++;
            }
        return c==1;
    }
}
