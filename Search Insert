Problem: Search Insert position
Difficulty: Easy

class Solution {
    public int searchInsert(int[] nums, int target) {
        int s=0;
        int n=nums.length-1;
        while(s<=n)
        {
            int mid=s+(n-s)/2;
            if(nums[mid]==target)
            {
                return mid;
            }
            else if(nums[mid]>target)
            {
                n=mid-1;
            }
            else
            {
                s=mid+1;
            }
        }
        return s;
    }
}
