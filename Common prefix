Problem: Longest common prifix
difficulty: easy

class Solution {
    public String longestCommonPrefix(String[] strs) {
       if(strs.length==0)
       {
        return "";
       }
       if(strs.length==1)
       {
        return strs[0];
       }
       int index=0;
       int longlength=strs[0].length();
       String lcp=strs[0];
       for(int i=0;i<strs.length;i++)
       {
        index=0;
        while(index<longlength&&index<strs[i].length())
        {
            if(lcp.charAt(index)!=strs[i].charAt(index))
            {
                break;
            }
            index++;
        }
        longlength=index;
       }
       return lcp.substring(0,longlength);
    }
}
